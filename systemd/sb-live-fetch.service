[Unit]
Description=SB Watchbot live data fetch (Databento 1m)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/sb-watchbot
EnvironmentFile=/etc/sb-watchbot/env
Environment=PATH=/opt/sb-watchbot/.venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin
ExecStart=/bin/bash /opt/sb-watchbot/scripts/live_fetch_nq.sh
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target

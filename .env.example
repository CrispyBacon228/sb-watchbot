# Copy to .env and fill in real values locally (never commit .env)

# Databento (create/rotate in your Databento console)
DATABENTO_API_KEY=YOUR_DB_KEY_HERE

# Dataset/schema from CME feed
DB_DATASET=GLBX.MDP3
DB_SCHEMA=ohlcv-1m

# Contract symbol (front month NQ; update when rolls)
FRONT_SYMBOL=NQU5

# Scale raw nanodollar prices to “normal”
PRICE_DIVISOR=1000000000

# Discord webhook for alerts (must start with https://discord.com/api/webhooks/)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXX/XXXXX

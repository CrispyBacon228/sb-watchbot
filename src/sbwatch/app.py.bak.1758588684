env_path = (Path(__file__).resolve().parents[2] / ".env")
if env_path.exists():
    load_dotenv(env_path)

# --- levels.json loader -------------------------------------------------------
from sbwatch.core.levels import DayLevels  # dataclass with as_dict()

def load_levels_json(path: str = "data/levels.json") -> DayLevels | None:
    """Load DayLevels from a JSON file written by `sbwatch build-levels`.
    Returns None if the file doesn't exist or can't be parsed."""
    fp = Path(path)
    if not fp.exists():
        return None
    try:
        obj = json.loads(fp.read_text())
        # Accept either exact dataclass keys or a superset
        # (unknown keys are ignored by **obj if they match dataclass fields)
        return DayLevels(
            date=obj.get("date"),
            pdh=obj.get("pdh"),
            pdl=obj.get("pdl"),
            asia_high=obj.get("asia_high"),
            asia_low=obj.get("asia_low"),
            london_high=obj.get("london_high"),
            london_low=obj.get("london_low"),
        )
    except Exception:
        return None

# --- shim: export run_replay for CLI ---
try:
    # Import the actual implementation if it exists somewhere else:
    from sbwatch.core.engine import run_replay as _run_replay  # adjust if needed
except Exception:
    _run_replay = None


try:
    from sbwatch._oldreplay_app import run_replay as _legacy_run_replay
except Exception:
    try:
        from sbwatch._oldreplay_app import replay as _legacy_run_replay
    except Exception:
        _legacy_run_replay = None

def run_replay(date: str, verbose: bool = False):
    """CLI shim: call legacy replay if available, else raise a clear error."""
    if _legacy_run_replay is None:
        raise ImportError(
            "run_replay implementation not found in sbwatch._oldreplay_app; "
            "no legacy replay available."
        )
    return _legacy_run_replay(date, verbose=verbose)


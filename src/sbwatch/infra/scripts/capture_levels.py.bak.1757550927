#!/usr/bin/env python3
from __future__ import annotations
import os, sys, json, traceback
from datetime import datetime, date, time, timedelta, timezone
from zoneinfo import ZoneInfo

# ----- Config -----
DATASET    = os.getenv("DB_DATASET",   "GLBX.MDP3")
SCHEMA     = os.getenv("DB_SCHEMA",    "ohlcv-1m")        # must be valid schema
SYMBOL     = os.getenv("FRONT_SYMBOL", "ES.f")
LEVELS_FP  = "/opt/sb-watchbot/data/levels.json"
WEBHOOK    = os.getenv("DISCORD_WEBHOOK_URL", "")
DIVISOR    = float(os.getenv("PRICE_DIVISOR", "1e8"))     # <-- proper GLBX OHLCV scale

ET = ZoneInfo("America/New_York")

# ----- Live client -----
def get_live():
    """
    Try our shim first; if unavailable, import the upstream Live client correctly.
    """
    try:
        sys.path.insert(0, "/opt/sb-watchbot")
        from sbw.db_live import Live  # our shim, if present
    except Exception:
        from databento.live.client import Live  # correct fallback path
    key = os.getenv("DATABENTO_API_KEY", "")
    if not key:
        raise RuntimeError("DATABENTO_API_KEY is not set")
    return Live(key=key)

# ----- Timeseries accessor -----
def get_ts_api(live_client):
    """
    Find an HTTP timeseries accessor that implements .get_range(...).
    If the Live client doesn't expose one, fall back to TimeseriesHttpAPI.
    """
    for path in ("timeseries", "timeseries_http"):
        api = getattr(live_client, path, None)
        if api and hasattr(api, "get_range"):
            return api

    http = getattr(live_client, "http", None)
    if http:
        api = getattr(http, "timeseries", None)
        if api and hasattr(api, "get_range"):
            return api

    # last-resort: direct HTTP client
    try:
        from databento import TimeseriesHttpAPI
        return TimeseriesHttpAPI(api_key=os.getenv("DATABENTO_API_KEY", ""))
    except Exception as e:
        raise RuntimeError(f"Could not locate a timeseries HTTP API: {e}")

# ----- Notify -----
def notify(msg: str) -> None:
    if not WEBHOOK:
        print(msg); return
    try:
        import requests
        r = requests.post(WEBHOOK, json={"content": msg}, timeout=10)
        print(f"discord status: {r.status_code}")
    except Exception:
        print("Discord POST failed:\n" + traceback.format_exc(), file=sys.stderr)

# ----- Sessions -----
def session_window_utc(d: date, which: str):
    # london: 02:00–05:00 ET (same day)
    # asia:   18:00–00:00 ET (evening prior day -> midnight of day d)
    if which == "london":
        start = datetime.combine(d, time(2,0), ET)
        end   = datetime.combine(d, time(5,0), ET)
    elif which == "asia":
        start = datetime.combine(d - timedelta(days=1), time(18,0), ET)
        end   = datetime.combine(d, time(0,0), ET)
    else:
        raise ValueError(f"unknown session {which!r}")
    return start.astimezone(timezone.utc), end.astimezone(timezone.utc)

# ----- Fetch -----
def fetch_range(ts_api, start_utc: datetime, end_utc: datetime):
    rows = ts_api.get_range(
        dataset=DATASET,
        schema=SCHEMA,             # IMPORTANT: parameter is 'schema'
        symbols=[SYMBOL],
        start=start_utc,
        end=end_utc,
    )
    return list(rows)

# ----- Build -----
def build_levels_for_day(live_client, d: date) -> dict:
    ts_api = get_ts_api(live_client)
    out = {
        "asia":   {"high": 0, "low": 0, "start": "18:00", "end": "00:00"},
        "london": {"high": 0, "low": 0, "start": "02:00", "end": "05:00"},
        "prev_day": {"high": 0, "low": 0},
    }

    def hi_lo(r):
        # handle namedtuple or dict
        h = getattr(r, "high", None)
        l = getattr(r, "low",  None)
        if isinstance(r, dict):
            h = r.get("high", h); l = r.get("low", l)
        return h, l

    for name in ("asia", "london"):
        s_utc, e_utc = session_window_utc(d, name)
        hi = lo = None
        for r in fetch_range(ts_api, s_utc, e_utc):
            h, l = hi_lo(r)
            if h is None or l is None:
                continue
            hi = h if hi is None else max(hi, h)
            lo = l if lo is None else min(lo, l)
        if hi is not None and lo is not None:
            out[name]["high"] = round(float(hi) / DIVISOR, 2)
            out[name]["low"]  = round(float(lo) / DIVISOR,  2)

    return out

# ----- Save -----
def save_levels(for_day: date, payload: dict):
    os.makedirs(os.path.dirname(LEVELS_FP), exist_ok=True)
    try:
        data = json.load(open(LEVELS_FP)) if os.path.exists(LEVELS_FP) else {}
    except Exception:
        data = {}
    key = for_day.strftime("%Y-%m-%d")
    data[key] = payload
    with open(LEVELS_FP, "w") as f:
        json.dump(data, f, indent=2)

# ----- Entrypoint -----
def main():
    try:
        today_et = datetime.now(ET).date()
        client = get_live()
        levels = build_levels_for_day(client, today_et)
        save_levels(today_et, levels)
        msg = (
            f"📈 SB Watchbot levels captured for {today_et} — "
            f"ASIA H/L: {levels['asia']['high']}/{levels['asia']['low']} | "
            f"LONDON H/L: {levels['london']['high']}/{levels['london']['low']}"
        )
        notify(msg)
        print("OK")
    except Exception:
        notify(f"❌ SB Watchbot levels capture FAILED:\n```{traceback.format_exc()[-1800:]}```")
        print(traceback.format_exc(), file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
